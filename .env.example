# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=8083

# ─── Base de dados (PostgreSQL) ───────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/commerce_db
