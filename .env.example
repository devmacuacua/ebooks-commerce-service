SPRING_DATASOURCE_PASSWORD=ebooks_secret

# ─── Redis ────────────────────────────────────────────────────────────────────
SPRING_DATA_REDIS_URL=redis://localhost:6379

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=ebooks
SPRING_RABBITMQ_PASSWORD=ebooks_secret

